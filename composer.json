{
    "name": "omniphx/forrest",
    "description": "A Laravel library for Salesforce",
    "license": "MIT",
    "keywords": [
        "salesforce",
        "laravel",
        "rest",
        "force.com",
        "force"
    ],
    "authors": [
        {
            "name": "Matthew Mitchener",
            "homepage": "http://mattmitchener.com",
            "email": "mattjmitchener@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "~7.2 || ~8.0",
        "firebase/php-jwt": "^5.2|~6.0|~7.0",
        "illuminate/cache": "~6.0|~7.0|~8.0|~9.0|~10.0|~11.0|~12.0 || ^13.0",
        "illuminate/contracts": "~6.0|~7.0|~8.0|~9.0|~10.0|~11.0|~12.0 || ^13.0",
        "illuminate/config": "~6.0|~7.0|~8.0|~9.0|~10.0|~11.0|~12.0 || ^13.0",
        "illuminate/http": "~6.0|~7.0|~8.0|~9.0|~10.0|~11.0|~12.0 || ^13.0",
        "illuminate/routing": "~6.0|~7.0|~8.0|~9.0|~10.0|~11.0|~12.0 || ^13.0",
        "nesbot/carbon": "^2.0|^3.0",
        "guzzlehttp/guzzle": "~6.0|~7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5 || ^9.6 || ^10.5 || ^11.5 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Omniphx\\Forrest\\": "src/Omniphx/Forrest/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Omniphx\\Forrest\\Providers\\Laravel\\ForrestServiceProvider"
            ],
            "aliases": {
                "Forrest": "Omniphx\\Forrest\\Providers\\Laravel\\Facades\\Forrest"
            }
        }
    }
}
